(
  nwchem = (
    basis = "sto-3g",
    theory = "pspw",
    scfType = "pbe96",
    charge = 0,
    multiplicity = 1,
    nwchemRoot = "@NWCHEM_ROOT@",
    task = "stress",
    scratchDir = "@NWCHEMC_TEST_SCRATCH@-pspw-stress",
    permanentDir = "@NWCHEMC_TEST_PERMANENT@-pspw-stress",
    inputBlocks = [
      "nwpw\n  simulation_cell\n    ngrid 8 8 8\n  end\n  cutoff 3.0\n  ewald_ncut 4\n  lcao\nend\nset nwpw:cutoff_boot_psi .false.\nset nwpw:lcao_iterations 8"
    ],
    inputStanzas = [
      (
        kind = pseudopotential,
        pseudopotential = (
          entries = [
            (element = "Si", libraryType = library, libraryName = "sg15")
          ]
        )
      )
    ]
  )
)
