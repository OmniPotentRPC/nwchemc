echo
start h2_selci_forces
title "H2 SELCI gradient"
geometry units angstrom noautosym
  H 0.0 0.0 -0.3707
  H 0.0 0.0  0.3707
end
basis spherical
  H library sto-3g
end
scf
  thresh 1e-8
end
set selci:nroot 1
set selci:mode select
set "selci:selection thresholds" 0.0
set selci:moints:force logical .true.
set selci:exci 2
task selci gradient
