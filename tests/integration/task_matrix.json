{
  "version": 1,
  "description": "Integration / CLI compare task matrix for nwchemc vs NWChem CLI",
  "tolerances": {
    "energy_ha_abs": 1e-05,
    "gradient_ha_bohr_abs": 0.0001,
    "position_ang_abs": 0.001,
    "frequency_cm1_abs": 50.0
  },
  "tasks": [
    {
      "id": "h2_scf_energy",
      "nw_input": "tests/integration/nw/h2_scf_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": true,
      "embed_meson_test": "nwchem-energy-gradient",
      "notes": "CLI task scf energy; embed NWChemParams energy/gradient ABI"
    },
    {
      "id": "h2_scf_gradient",
      "nw_input": "tests/integration/nw/h2_scf_gradient.nw",
      "quantities": [
        "energy",
        "gradient"
      ],
      "embed_compare": true,
      "embed_meson_test": "nwchem-energy-gradient",
      "notes": "CLI task scf gradient; embed energy+gradient within tol"
    },
    {
      "id": "h2_scf_optimize",
      "nw_input": "tests/integration/nw/h2_scf_optimize.nw",
      "quantities": [
        "energy",
        "optimized_positions"
      ],
      "embed_compare": true,
      "embed_meson_test": "nwchem-optimize-scf",
