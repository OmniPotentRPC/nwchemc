{
  "version": 1,
  "description": "Integration / CLI compare task matrix for nwchemc vs NWChem CLI",
  "tolerances": {
    "energy_ha_abs": 1e-05,
    "gradient_ha_bohr_abs": 0.0001
  },
  "tasks": [
    {
      "id": "h2_scf_energy",
      "nw_input": "tests/integration/nw/h2_scf_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": true,
      "embed_meson_test": "nwchem-energy-gradient",
      "notes": "CLI task scf energy; embed NWChemParams energy/gradient ABI"
    },
    {
      "id": "h2_scf_gradient",
      "nw_input": "tests/integration/nw/h2_scf_gradient.nw",
      "quantities": [
        "energy",
        "gradient"
      ],
      "embed_compare": true,
      "embed_meson_test": "nwchem-energy-gradient",
      "notes": "CLI task scf gradient; embed energy+gradient within tol"
    },
    {
      "id": "h2_scf_optimize",
      "nw_input": "tests/integration/nw/h2_scf_optimize.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-rgpot-smoke",
      "notes": "CLI task scf optimize finite energy; embed optimize via Meson/rgpot smoke not this JSON leg"
    },
    {
      "id": "h2_scf_frequencies",
      "nw_input": "tests/integration/nw/h2_scf_frequencies.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-rgpot-smoke",
      "notes": "CLI task scf freq finite energy; frequencies spectrum Meson-tested, not CLI-embed JSON"
    },
    {
      "id": "h2_ccsd_energy",
      "nw_input": "tests/integration/nw/h2_ccsd_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-postscf-energy-ccsd",
      "notes": "CLI task ccsd energy; embed nwchemc_energy theory=ccsd finite energy"
    },
    {
      "id": "h2_mp2_energy",
      "nw_input": "tests/integration/nw/h2_mp2_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-postscf-energy-mp2",
      "notes": "CLI task mp2 energy; embed nwchemc_energy theory=mp2 finite energy"
    },
    {
      "id": "h2_tce_energy",
      "nw_input": "tests/integration/nw/h2_tce_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-postscf-energy-tce",
      "notes": "CLI task tce energy; embed nwchemc_energy theory=tce + tce:model ccsd"
    },
    {
      "id": "h2_dft_energy",
      "nw_input": "tests/integration/nw/h2_dft_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-postscf-energy-dft",
      "notes": "CLI task dft energy; embed theory=dft B3LYP"
    },
    {
      "id": "h2_rimp2_energy",
      "nw_input": "tests/integration/nw/h2_rimp2_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-postscf-energy-rimp2",
      "notes": "CLI task rimp2 energy; embed theory=rimp2"
    },
    {
      "id": "h2_tce_ccsdt_energy",
      "nw_input": "tests/integration/nw/h2_tce_energy.nw",
      "quantities": [
        "energy"
      ],
      "embed_compare": false,
      "embed_meson_test": "nwchem-postscf-energy-tce-ccsdt",
      "notes": "CLI tce; embed TCE model ccsd + perturbative (t)"
    }
  ]
}
